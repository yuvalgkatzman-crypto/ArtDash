<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A3A"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="350dp"
        app:cardBackgroundColor="#050510"
        app:cardCornerRadius="25dp">
        <ImageView
            android:id="@+id/ivLargeImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnToggleTop"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#D946EF"
        android:text="Add to Top 3"
        app:cornerRadius="20dp" />

    <Button
        android:id="@+id/btnSaveLocal"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="#8B5CF6"
        android:text="Save to Phone Gallery"
        app:cornerRadius="20dp" />

    <Button
        android:id="@+id/btnDeleteDrawing"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="#EF4444"
        android:text="Delete Drawing"
        app:cornerRadius="20dp" />

</LinearLayout>